---
# LambChat Secrets
# Copy this file to lambchat-secret.yaml and fill in your values
# DO NOT commit lambchat-secret.yaml to git
apiVersion: v1
kind: Secret
metadata:
  name: lambchat-secrets
  namespace: lambchat
type: Opaque
stringData:
  jwt-secret-key: "YOUR_JWT_SECRET_KEY"
  mcp-encryption-salt: "YOUR_MCP_ENCRYPTION_SALT"
  llm-api-key: "YOUR_LLM_API_KEY"
  anthropic-api-key: "YOUR_ANTHROPIC_API_KEY"
  redis-password: "YOUR_REDIS_PASSWORD"
  postgres-password: "YOUR_POSTGRES_PASSWORD"
  mongodb-username: "YOUR_MONGODB_USERNAME"
  mongodb-password: "YOUR_MONGODB_PASSWORD"
  s3-access-key: "YOUR_S3_ACCESS_KEY"
  s3-secret-key: "YOUR_S3_SECRET_KEY"
  langsmith-api-key: "YOUR_LANGSMITH_API_KEY"
  openviking-api-key: "YOUR_OPENVIKING_API_KEY"
  daytona-api-key: "YOUR_DAYTONA_API_KEY"
  e2b-api-key: "YOUR_E2B_API_KEY"
